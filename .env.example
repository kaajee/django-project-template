# Copy to .env and fill in. Never commit the real .env.

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_DEFAULT_FROM_EMAIL=webmaster@localhost

# --- Production-only hardening (used by config.settings.prod) ---
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://postgres:postgres@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- CORS (comma-separated origins for SPA/mobile clients) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting ---
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=1000/min

# --- allauth headless JWT ---
# HS256 (default) uses SECRET_KEY when the private key is blank.
# For RS256, set HEADLESS_JWT_ALGORITHM=RS256 and provide a PEM private key.
HEADLESS_JWT_ALGORITHM=HS256
HEADLESS_JWT_PRIVATE_KEY=
HEADLESS_JWT_ACCESS_TOKEN_EXPIRES_IN=300
HEADLESS_JWT_REFRESH_TOKEN_EXPIRES_IN=86400
ACCOUNT_EMAIL_VERIFICATION=mandatory

# --- Social login (Google example; configure in admin or settings) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Datadog APM (process is run under ddtrace-run when enabled) ---
DD_TRACE_ENABLED=false
DD_SERVICE=django-project-template
DD_ENV=production
DD_VERSION=1.0.0
DD_AGENT_HOST=datadog-agent
DD_LOGS_INJECTION=true

# --- Logging ---
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_FORMATTER=console
